#!/usr/bin/env bash

set -euo pipefail

# Validates a list of images against a target image list file
# Arguments:
#   $1: Path to the definition file containing images to check (e.g., rancher-images.txt)
#   $2: Path to the target image list file to validate against
validate_images_from_file() {
    local def_file="$1"
    local target_file="$2"

    if [[ ! -f "${target_file}" ]]; then
        echo "NOTE: Target file '${target_file}' does not exist, skipping validation." >&2
        return 1
    fi

    if [[ ! -f "${def_file}" ]]; then
        echo "ERROR: Image definition file '${def_file}' not found." >&2
        return 2
    fi

    local missing_count=0

    # Read the definition file line by line
    # 1. Strip trailing carriage returns (CRLF handling)
    # 2. Remove leading/trailing whitespace
    # 3. Skip empty lines and lines starting with '#'
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Clean the line
        line=$(echo "$line" | sed -e 's/\r//g' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

        # Skip comments and empty lines
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        # Validate against the target file
        if ! grep -qw -F "${line}" "${target_file}"; then
            echo "FAIL: Image [${line}] not found in ${target_file}" >&2
            ((missing_count++))
        else
            echo "OK:   Image [${line}] is present"
        fi
    done < "${def_file}"

    if (( missing_count > 0 )); then
        echo "Validation failed: ${missing_count} image(s) missing." >&2
        return 1
    fi

    echo "All images successfully validated!"
    return 0
}

# Example Usage:
# validate_images_from_file "rancher-images.txt" "path/to/target_file.txt"

# called by the ISO installer to validate the rancher-monitoring and rancher-logging images
# validate_rancher_monitoring_logging_images_from_file "$1"
validate_rancher_monitoring_logging_images_from_file() {
# Dynamically find the absolute path of the script's directory
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # Resolve the text file relative to the script location
    # (Assumes chart-image-lists.txt is in a 'hack' directory adjacent to the script,
    # adjust the relative path here if the script itself lives inside 'hack/')
    local def_file="${script_dir}/hack/chart-image-lists.txt"
    validate_images_from_file "${def_file}" "$1"
}
